{
  "name": "observing",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized biodiversity platform on AT Protocol",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "scripts": {
    "build": "vite build -c frontend/vite.config.ts",
    "build-storybook": "storybook build",
    "check:stories": "node scripts/check-stories.mjs",
    "generate-rust-types": "./scripts/generate-rust-types.sh",
    "dev": "vite -c frontend/vite.config.ts",
    "fmt": "oxfmt frontend/src tests scripts",
    "fmt:check": "oxfmt --check frontend/src tests scripts",
    "lint": "oxlint frontend/src",
    "storybook": "storybook dev -p 6006",
    "test": "playwright test --config=tests/playwright.config.ts",
    "test:e2e": "playwright test --config=tests/playwright.config.ts --project=e2e",
    "test:integration": "playwright test --config=tests/playwright.config.ts --project=integration"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-date-pickers": "^9.0.4",
    "@mui/x-tree-view": "^9.0.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@xmldom/xmldom": "^0.9.9",
    "capacitor-original-photo-picker": "github:observ-ing/capacitor-original-photo-picker",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.2",
    "exifreader": "^4.38.1",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@atproto/api": "^0.19.12",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "msw": "^2.14.3",
    "msw-storybook-addon": "^2.0.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "storybook": "^10.3.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "serialize-javascript": "^7.0.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
