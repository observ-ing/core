    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.2.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.7.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
