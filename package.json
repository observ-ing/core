{
  "name": "observing",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized biodiversity platform on AT Protocol",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "scripts": {
    "build": "vite build -c frontend/vite.config.ts",
    "generate-rust-types": "./scripts/generate-rust-types.sh",
    "dev": "vite -c frontend/vite.config.ts",
    "fmt": "oxfmt frontend/src tests scripts",
    "fmt:check": "oxfmt --check frontend/src tests scripts",
    "lint": "oxlint frontend/src",
    "test": "playwright test --config=tests/playwright.config.ts",
    "test:e2e": "playwright test --config=tests/playwright.config.ts --project=e2e",
    "test:integration": "playwright test --config=tests/playwright.config.ts --project=integration"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/x-date-pickers": "^8.27.0",
    "@mui/x-tree-view": "^8.27.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@xmldom/xmldom": "^0.9.9",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "exifreader": "^4.36.1",
    "maplibre-gl": "^5.17.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@atproto/api": "^0.19.5",
    "@playwright/test": "^1.59.0",
    "@types/dompurify": "^3.0.5",
