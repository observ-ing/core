{
  "name": "observing",
  "version": "0.1.0",
  "private": true,
  "description": "Decentralized biodiversity platform on AT Protocol",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "scripts": {
    "build": "vite build -c frontend/vite.config.ts",
    "build-storybook": "storybook build",
    "check:stories": "node scripts/check-stories.mjs",
    "doctor": "./scripts/doctor.sh",
    "generate-rust-types": "./scripts/generate-rust-types.sh",
    "setup": "./scripts/setup.sh",
    "dev": "vite -c frontend/vite.config.ts",
    "fmt": "oxfmt frontend/src frontend/tests scripts",
    "fmt:check": "oxfmt --check frontend/src frontend/tests scripts",
    "lint": "oxlint frontend/src",
    "storybook": "storybook dev -p 6006",
    "test": "playwright test --config=frontend/tests/playwright.config.ts",
    "test:e2e": "playwright test --config=frontend/tests/playwright.config.ts --project=e2e",
    "test:integration": "playwright test --config=frontend/tests/playwright.config.ts --project=integration",
    "test:unit": "vitest run --config frontend/vitest.config.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/x-date-pickers": "^9.2.0",
    "@mui/x-tree-view": "^9.1.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/query-async-storage-persister": "^5.100.14",
    "@tanstack/query-persist-client-core": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "@xmldom/xmldom": "^0.9.10",
    "capacitor-original-photo-picker": "github:observ-ing/capacitor-original-photo-picker",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.3",
    "exifreader": "^4.38.1",
    "idb-keyval": "^6.2.4",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@atproto/api": "^0.19.18",
    "@capacitor/cli": "^8.3.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-themes": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "storybook": "^10.3.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "serialize-javascript": "^7.0.5"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
