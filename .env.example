# observ.ing — local development environment
#
# Copy this file to `.env` and adjust as needed:
#   cp .env.example .env
#
# `.env` is gitignored. Source it once per shell with:
#   set -a && source .env && set +a
#
# (process-compose reads it automatically when started from this directory.)
#
# See docs/development.md for the full setup walkthrough.


# ---------------------------------------------------------------------------
# Database (required)
# ---------------------------------------------------------------------------
# Connection to local PostgreSQL with the PostGIS extension.
#
# Either set DATABASE_URL directly, OR set DB_HOST / DB_NAME / DB_USER /
# DB_PASSWORD / DB_PORT individually (production uses the latter form to
# point at a Cloud SQL socket). DATABASE_URL wins if both are set.
#
# The docker recipe in docs/development.md uses password `mysecretpassword`;
# change it here if you used a different one.

DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/observing

# Used only by `process-compose.yaml` when DATABASE_URL is unset (so the
# default URL it composes has a real password). Safe to leave blank if
# DATABASE_URL is set above.
DB_PASSWORD=mysecretpassword


# ---------------------------------------------------------------------------
# AppView (port 3000) — main REST API + OAuth + static file serving
# ---------------------------------------------------------------------------

# HTTP port. process-compose sets this to 3000 for appview.
# PORT=3000

# Local dev ports are randomizable so several checkouts can run at once.
# `npm run dev:stack` (scripts/dev.sh) picks one random offset and derives
# all of these; set them by hand only to pin specific ports. See
# docs/development.md. Postgres (5432) is deliberately not offset.
# DEV_PORT_OFFSET=        # pin the offset the wrapper applies (0 = stock ports)
# APPVIEW_PORT=3000
# SPECIES_ID_PORT=3005
# VITE_PORT=5173
# TAP_INGESTER_PORT=8080

# Where the appview proxies frontend requests when no static bundle exists.
# Defaults to the Vite dev server on 5173; the wrapper points it at VITE_PORT.
# VITE_DEV_SERVER_URL=http://localhost:5173

# Where the media proxy caches resized images. Created on first run.
CACHE_DIR=./cache/media

# Optional: cap on cache size in bytes. Default: unlimited.
# MAX_CACHE_SIZE=

# Optional: cached-entry TTL in seconds. Default: forever.
# CACHE_TTL_SECS=

# Public-facing URL. Leave blank locally; production sets https://observ.ing.
PUBLIC_URL=

# Where species-id lives. Default targets the process-compose service.
SPECIES_ID_SERVICE_URL=http://localhost:3005

# Comma-separated DIDs to hide from feeds (e.g. the e2e test account).
# HIDDEN_DIDS=

# Comma-separated DIDs that get admin-only routes.
# ADMIN_DIDS=

# Comma-separated allowed CORS origins.
# CORS_ORIGINS=

# Override the PLC directory used to resolve did:plc identities (appview OAuth,
# identity resolver, and blob resolver). Defaults to https://plc.directory.
# Point this at a local @atproto/dev-env PLC for isolated e2e tests.
# PLC_DIRECTORY_URL=https://plc.directory

# Override handle (handle -> DID) resolution. Unset = spec-default decentralized
# resolution (DNS TXT + .well-known), which is what production uses. When set,
# both the OAuth client and the identity resolver resolve handles via this URL's
# com.atproto.identity.resolveHandle instead. Point at a local @atproto/dev-env
# PDS for isolated e2e, where `.test` handles cannot resolve via DNS.
# HANDLE_RESOLVER_URL=

# Override where the appview serves built static files from. Default:
# `dist/public`. If the directory is empty, appview proxies frontend
# requests to the Vite dev server instead.
# PUBLIC_PATH=dist/public


# ---------------------------------------------------------------------------
# Frontend (Vite) — VITE_-prefixed vars are baked into the browser bundle
# ---------------------------------------------------------------------------
# Read at build/dev time and exposed to the client, so treat these as public.

# MapTiler API key for the map basemap (Outdoor — label-rich topo, light+dark).
# Create a free key at https://cloud.maptiler.com (Account -> Keys) and, since
# it ships in the bundle, restrict it to your domain(s) in the MapTiler
# dashboard. If unset, the map falls back to keyless CARTO vector tiles.
# VITE_MAPTILER_KEY=

# Optional: override the API base URL the frontend calls. Default: same origin.
# VITE_API_URL=


# ---------------------------------------------------------------------------
# species-id (port 3005) — ML-based species identification
# ---------------------------------------------------------------------------

# Directory containing the BioCLIP ONNX model files (~1.4 GB).
# Run `./scripts/download-models.sh` once to populate.
MODEL_DIR=./models/bioclip

# Path to the ONNX Runtime dynamic library.
# - macOS (Apple Silicon, Homebrew): /opt/homebrew/lib/libonnxruntime.dylib
# - macOS (Intel, Homebrew):         /usr/local/lib/libonnxruntime.dylib
# - Linux (apt/dnf):                 /usr/lib/x86_64-linux-gnu/libonnxruntime.so
# Install with `brew install onnxruntime` (macOS) or your distro package.
ORT_DYLIB_PATH=/opt/homebrew/lib/libonnxruntime.dylib


# ---------------------------------------------------------------------------
# tap-ingester (port 8080) — AT Protocol firehose consumer
# ---------------------------------------------------------------------------
# Spawns the upstream `tap` Go binary as a child process. See
# docs/development.md for how to build and install `tap` on PATH.

# Backing store for the embedded Tap. Sqlite is fine for local dev;
# production uses Postgres with a `tap` schema search_path.
TAP_DATABASE_URL=sqlite:./.tap-ingester/tap.db

# Set to skip spawning Tap and connect to an existing instance (e.g. one
# you're running in Docker).
# TAP_URL=

# Override the upstream firehose Tap subscribes to (a relay or, for e2e, a
# single PDS's com.atproto.sync.subscribeRepos). Unset = Tap's built-in public
# relay default. Pair with PLC_DIRECTORY_URL to point Tap at a local
# @atproto/dev-env network. The lag probe tracks this automatically.
# TAP_RELAY_URL=

# Basic-auth password for Tap's admin endpoints. Optional locally.
# TAP_ADMIN_PASSWORD=

# Set to any value to forward the spawned Tap's stdout/stderr to the
# parent process (helpful when debugging tap-ingester startup).
# TAP_INHERIT_STDIO=1


# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Per-crate level via tracing's EnvFilter syntax. Drop to `debug` or
# `trace` for noisier output.
RUST_LOG=info,observing_appview=debug,tap_ingester=debug


# ---------------------------------------------------------------------------
# E2E tests (only needed for `npm run test:e2e`)
# ---------------------------------------------------------------------------
# A real Bluesky account used by tests/auth.setup.ts to perform OAuth.
# Create a throwaway account at https://bsky.app — never use a personal
# one, since the tests authorize the local app against it.

# BLUESKY_TEST_EMAIL=you+observing-e2e@example.com
# BLUESKY_TEST_PASSWORD=
# BLUESKY_TEST_HANDLE=youre2e.bsky.social
